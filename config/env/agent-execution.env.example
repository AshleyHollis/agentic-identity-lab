# ---------------------------------------------------------------------------
# Offline mock token flow — no Azure tenant required
# ---------------------------------------------------------------------------
# 1. AUTH_MODE=mock (default) — token validation runs fully offline against a
#    built-in fixture library.  No Entra tenant, no network calls, no secrets.
# 2. AUTH_FIXTURE (or request header X-Identity-Lab-Fixture) selects which
#    mock identity is injected (e.g. delegated-user, app-client, guest-user).
# 3. Replace {tenant_id} placeholders ONLY when switching to AUTH_MODE=strict;
#    AUTH_ISSUER and AUTH_JWKS_URL are ignored in mock mode.
# 4. All GUIDs in this file are all-zero placeholders — replace with real
#    values for strict mode.  Do NOT commit real tenant IDs or secrets.
# ---------------------------------------------------------------------------

SERVICE_NAME=identity-lab-agent-execution
PORT=8000
LOG_LEVEL=info

# Auth mode: disabled | mock | strict (keep mock for local/offline)
AUTH_MODE=mock
# Mock fixture selection (header X-Identity-Lab-Fixture overrides env)
AUTH_FIXTURE=delegated-user

# Future strict Entra placeholders (replace {tenant_id} with real values later)
AUTH_ISSUER=https://login.microsoftonline.com/{tenant_id}/v2.0
AUTH_JWKS_URL=https://login.microsoftonline.com/{tenant_id}/discovery/v2.0/keys

# Service-specific audience/scope enforcement
ALLOWED_AUDIENCES=api://00000000-0000-0000-0000-000000000102
REQUIRED_SCOPES=mcp.access,mcp.write

# Trusted tenant allowlist (placeholder; update for strict)
TRUSTED_TENANTS=00000000-0000-0000-0000-000000000000
ENABLE_DEBUG_CLAIMS=false
CORRELATION_HEADER=x-correlation-id
MCP_CHAIN_ENABLED=false
MCP_PROTECTED_API_BASE_URL=http://mcp-protected-api:8080
MCP_AUTHORIZATION_CHECK_PATH=/tools/authorization-check
DOWNSTREAM_TIMEOUT_SECONDS=10

# On-Behalf-Of (OBO) vars — agent-execution forwards delegated tokens downstream.
# In mock mode these are validated structurally only; no real Entra OBO exchange occurs.
# Replace with real audience/scope values for strict mode.
OBO_DOWNSTREAM_AUDIENCE=api://00000000-0000-0000-0000-000000000103
OBO_REQUIRED_SCOPES=mcp.access,mcp.write

# Agent blueprint audience — the expected 'aud' claim on inbound bearer tokens before
# any Agent OBO exchange.  Must be set to the real app registration URI in strict mode.
# Placeholder value causes startup failure when AUTH_MODE=strict (T12 binding condition C1).
# Example (strict mode): BLUEPRINT_AUDIENCE=api://{client-id}/access_as_user
# BLUEPRINT_AUDIENCE=api://00000000-0000-0000-0000-000000000201/access_as_user

# ---------------------------------------------------------------------------
# OpenTelemetry / Azure Monitor OTLP configuration
# ---------------------------------------------------------------------------
# ADR-M6-02: OTLP endpoint env var swap — zero code change from M5 instrumentation.
#
# Local / offline (Jaeger or OTEL collector):
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
#
# Azure Monitor (ACA deployment — M6):
#   Set OTEL_EXPORTER_OTLP_ENDPOINT to your workspace-linked Application Insights
#   OTLP ingestion endpoint.  Format:
#     OTEL_EXPORTER_OTLP_ENDPOINT=https://{region}.otel.monitor.azure.com/v1/traces
#   The region matches your Log Analytics workspace region (e.g. eastus, westeurope).
#   No connection string or instrumentation key is embedded here — use managed identity
#   or a Key Vault reference for any secret access; never commit real keys to source.
#
# Security constraints (identity_lab_auth/telemetry.py):
#   - Raw bearer token strings MUST NOT be set as span attributes.
#   - PII claim keys (oid, sub, email, upn, name, preferred_username,
#     given_name, family_name) MUST NOT be set as span attributes.
#   - identity_lab.fixture_name is always blank ("") in strict mode.
#
# Disable all tracing in test environments:
#   OTEL_SDK_DISABLED=true
#
# Leave OTEL_EXPORTER_OTLP_ENDPOINT unset to use the no-op tracer (offline/dev default).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SDK_DISABLED=true
