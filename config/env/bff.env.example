# ---------------------------------------------------------------------------
# Offline mock token flow — no Azure tenant required
# ---------------------------------------------------------------------------
# 1. AUTH_MODE=mock (default) — token validation runs fully offline against a
#    built-in fixture library.  No Entra tenant, no network calls, no secrets.
# 2. AUTH_FIXTURE (or request header X-Identity-Lab-Fixture) selects which
#    mock identity is injected (e.g. delegated-user, app-client, guest-user).
# 3. Replace {tenant_id} placeholders ONLY when switching to AUTH_MODE=strict;
#    AUTH_ISSUER and AUTH_JWKS_URL are ignored in mock mode.
# 4. All GUIDs in this file are all-zero placeholders — replace with real
#    values for strict mode.  Do NOT commit real tenant IDs or secrets.
# ---------------------------------------------------------------------------

SERVICE_NAME=identity-lab-bff
PORT=8000
LOG_LEVEL=info

# Auth mode: disabled | mock | strict (keep mock for local/offline)
AUTH_MODE=mock
# Mock fixture selection (header X-Identity-Lab-Fixture overrides env)
AUTH_FIXTURE=delegated-user

# Future strict Entra placeholders (replace {tenant_id} with real values later)
AUTH_ISSUER=https://login.microsoftonline.com/{tenant_id}/v2.0
AUTH_JWKS_URL=https://login.microsoftonline.com/{tenant_id}/discovery/v2.0/keys

# Service-specific audience/scope enforcement
ALLOWED_AUDIENCES=api://00000000-0000-0000-0000-000000000101
REQUIRED_SCOPES=mcp.access

# Trusted tenant allowlist (placeholder; update for strict)
TRUSTED_TENANTS=00000000-0000-0000-0000-000000000000
ENABLE_DEBUG_CLAIMS=false
CORRELATION_HEADER=x-correlation-id
CHAT_SESSION_CHAIN_ENABLED=false
AGENT_EXECUTION_BASE_URL=http://agent-execution:8080
AGENT_EXECUTION_INVOKE_PATH=/agent/invoke
DOWNSTREAM_TIMEOUT_SECONDS=10

# Strict/live delegated chain: BFF exchanges the inbound BFF-audience token for
# an Agent Execution audience/scope token before calling Agent. Values must be
# supplied from protected deployment inputs; do not commit real values.
OBO_TOKEN_URL=https://login.microsoftonline.com/{tenant_id}/oauth2/v2.0/token
OBO_CLIENT_ID=00000000-0000-0000-0000-000000000000
OBO_CLIENT_SECRET=
OBO_REQUIRED_SCOPES=api://00000000-0000-0000-0000-000000000102/.default

# CORS allowed origins for local browser clients (comma-separated; no wildcard with credentials).
# In AUTH_MODE=mock this defaults to http://localhost:3000 if unset.
# Leave unset (or remove) when AUTH_MODE=strict — CORS is disabled unless explicitly configured.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://localhost:4321

# OpenTelemetry / Azure Monitor OTLP configuration
# ADR-M6-02: OTLP endpoint env var swap — zero code change from M5 instrumentation.
#
# Local / offline (Jaeger or OTEL collector):
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
#
# Azure Monitor (ACA deployment — M6):
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://{region}.otel.monitor.azure.com/v1/traces
#   No connection string or instrumentation key is embedded here.
#
# Security constraints: raw bearer tokens and PII claims (oid, sub, email, upn,
# name, preferred_username, given_name, family_name) must never appear as span
# attributes.  identity_lab.fixture_name is always blank in strict mode.
#
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SDK_DISABLED=true
