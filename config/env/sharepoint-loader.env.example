# SharePoint classic loader placeholders
# Do not store real tenant IDs, client IDs, or tokens in this repo.

SHAREPOINT_LOADER_BFF_BASE_URL=https://YOUR_BFF_DOMAIN
SHAREPOINT_LOADER_CHAT_PATH=/chat/session
SHAREPOINT_LOADER_CONTAINER_ID=identity-chat-root
SHAREPOINT_LOADER_THEME=light
SHAREPOINT_LOADER_USER_ID_HINT=USER_DISPLAY_HINT

# userId is a display hint only; identity must come from tokens.
