# SPA public-client placeholders
# Do not store real tenant IDs, client IDs, or tokens in this repo.

VITE_BFF_BASE_URL=https://YOUR_BFF_DOMAIN
VITE_AUTHORITY=https://login.microsoftonline.com/YOUR_TENANT_ID
VITE_CLIENT_ID=YOUR_PUBLIC_CLIENT_ID
VITE_SCOPES=api://YOUR_RESOURCE/.default

NEXT_PUBLIC_BFF_BASE_URL=https://YOUR_BFF_DOMAIN
NEXT_PUBLIC_AUTHORITY=https://login.microsoftonline.com/YOUR_TENANT_ID
NEXT_PUBLIC_CLIENT_ID=YOUR_PUBLIC_CLIENT_ID
NEXT_PUBLIC_SCOPES=api://YOUR_RESOURCE/.default

# userId is a display hint only; identity must come from tokens.
