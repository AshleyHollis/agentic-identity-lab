# SPA public-client placeholders
# ---------------------------------------------------------------------------
# All GUIDs below are all-zero placeholders consistent with the repo
# placeholder convention (see config/env/bff.env.example).
# Replace with real values ONLY in local .env (never committed).
# Do NOT commit real tenant IDs, client IDs, secrets, or tokens.
# SECURITY: No implicit flow. Auth Code + PKCE only (MSAL browser default).
# SECURITY: Scope must NOT use .default on the BFF app ID — use the explicit
#           delegated scope only (e.g. api://<bff-app-id>/mcp.access).
# ---------------------------------------------------------------------------

# React / Vite SPA (apps/spa-public-client/react-vite/)
VITE_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000002
VITE_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000001
VITE_BFF_BASE_URL=http://localhost:8000
VITE_BFF_API_SCOPE=api://00000000-0000-0000-0000-000000000101/mcp.access

# Next.js SPA (apps/spa-public-client/nextjs/ — placeholder only in M7)
NEXT_PUBLIC_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000002
NEXT_PUBLIC_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_BFF_BASE_URL=http://localhost:8000
NEXT_PUBLIC_BFF_API_SCOPE=api://00000000-0000-0000-0000-000000000101/mcp.access

# userId is a display hint only; identity must come from the validated bearer token.
# MSAL cache location: sessionStorage (not localStorage) — see ADR-M7-01.
