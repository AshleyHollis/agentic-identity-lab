# Placeholder values only — replace before deployment.
# Do NOT commit real tenant IDs, subscription IDs, or secrets.
# Supply these values via tfvars at deploy time (not committed to this repository).

environment         = "dev"
location            = "eastus"
subscription_id     = "{subscription-id}"
tenant_id           = "{tenant-id}"
resource_group_name = "rg-agent-identity-lab-dev-aca"

# Container images — set to real ACR image refs at deploy time.
# bff_image             = "acrname.azurecr.io/bff:latest"
# agent_execution_image = "acrname.azurecr.io/agent-execution:latest"
# mcp_image             = "acrname.azurecr.io/mcp-protected-api:latest"

# Azure Monitor OTLP endpoint (ADR-M6-02).
# Replace {region} with your Azure Monitor workspace region (e.g., eastus).
# otel_endpoint = "https://{region}.otel.monitor.azure.com/v1/traces"

# Low-cost lab default. Override only with explicit cost approval.
apim_sku_name = "Consumption_0"

# Strict auth placeholders. Supply real tenant/app values at deploy time.
# auth_issuer                       = "https://login.microsoftonline.com/{tenant-id}/v2.0"
# auth_jwks_url                     = "https://login.microsoftonline.com/{tenant-id}/discovery/v2.0/keys"
# trusted_tenants                   = "{tenant-id}"
# bff_allowed_audiences             = "api://agent-identity-lab-dev-bff"
# agent_execution_allowed_audiences = "api://agent-identity-lab-dev-agent-execution"
# mcp_allowed_audiences             = "api://agent-identity-lab-dev-mcp"
# blueprint_audience                = "api://agent-identity-lab-dev-bff"
