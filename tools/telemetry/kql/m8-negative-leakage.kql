let lookback = 30m; let role_names = dynamic(['apim', 'bff', 'agent-execution', 'mcp-protected-api', 'identity-lab-bff', 'identity-lab-agent-execution', 'identity-lab-mcp-protected-api']); let compatibility_tokens = dynamic(['requests', 'dependencies', 'traces', 'ContainerAppConsoleLogs_CL']); let forbidden = dynamic(['authorization', 'bearer ', 'eyj', 'cookie', 'set-cookie', 'access_token', 'refresh_token', 'id_token', '"oid"', '"sub"', '"email"', '"upn"', '"preferred_username"', '"name"', '"given_name"', '"family_name"', 'tracestate']); union isfuzzy=true AppRequests, AppDependencies, AppTraces, ContainerAppConsoleLogs_CL | extend timestamp = TimeGenerated, signal = Type, cloud_RoleName = column_ifexists('AppRoleName', ''), operation_Id = column_ifexists('OperationId', '') | where timestamp > ago(lookback) | where isempty(cloud_RoleName) or cloud_RoleName in (role_names) | extend payload = strcat(tostring(column_ifexists('Properties', '')), ' ', tostring(column_ifexists('Message', '')), ' ', tostring(column_ifexists('Name', '')), ' ', tostring(column_ifexists('Url', '')), ' ', tostring(column_ifexists('Data', '')), ' ', tostring(column_ifexists('Target', '')), ' ', tostring(column_ifexists('Log_s', ''))) | extend payload_lower = tolower(payload) | where payload_lower contains_cs 'authorization' or payload_lower contains_cs 'bearer ' or payload_lower contains_cs 'eyj' or payload_lower contains_cs 'cookie' or payload_lower contains_cs 'set-cookie' or payload_lower contains_cs 'access_token' or payload_lower contains_cs 'refresh_token' or payload_lower contains_cs 'id_token' or payload_lower contains_cs 'tracestate' or payload_lower matches regex '"oid"\\s*:' or payload_lower matches regex '"sub"\\s*:' or payload_lower matches regex '"email"\\s*:' or payload_lower matches regex '"upn"\\s*:' or payload_lower matches regex '"preferred_username"\\s*:' or payload_lower matches regex '"name"\\s*:' or payload_lower matches regex '"given_name"\\s*:' or payload_lower matches regex '"family_name"\\s*:' | project timestamp, signal, cloud_RoleName, operation_Id, payload
