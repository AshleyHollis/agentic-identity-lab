let lookback = 30m; let role_names = dynamic(['apim', 'bff', 'agent-execution', 'mcp-protected-api', 'identity-lab-bff', 'identity-lab-agent-execution', 'identity-lab-mcp-protected-api']); let compatibility_tokens = dynamic(['requests', 'dependencies', 'traces', 'cloud_RoleName', 'operation_Id']); union isfuzzy=true AppRequests, AppDependencies, AppTraces | extend timestamp = TimeGenerated, tableName = Type, cloud_RoleName = AppRoleName, operation_Id = OperationId, operation_ParentId = ParentId, name = Name, resultCode = ResultCode | where timestamp > ago(lookback) | where cloud_RoleName in (role_names) | where isnotempty(operation_Id) | project timestamp, tableName, cloud_RoleName, operation_Id, operation_ParentId, name, resultCode | order by timestamp asc
